generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// 1. NextAuth Authentication Core (4 tables)
// ----------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  
  // Relations to SaaS logic
  subscription  Subscription?
  workspaces    Workspace[]
  transactions  Transaction[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------
// 2. Billing & Subscription (2 tables)
// ----------------------------------------------------
model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  tier            String    @default("FREE") // FREE, PRO, ENTERPRISE
  status          String    @default("ACTIVE") // ACTIVE, CANCELED, PAST_DUE
  yookassaPaymentId String?
  currentPeriodEnd DateTime?
  tokenBalance    Int       @default(10) // 10 queries for free tier
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  currency        String   @default("RUB")
  status          String   // PENDING, SUCCEEDED, CANCELED
  paymentMethod   String?
  yookassaId      String?  @unique
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 3. Cortex OS Workspaces & Agent Threads (3 tables)
// ----------------------------------------------------
model Workspace {
  id          String   @id @default(cuid())
  userId      String
  name        String   @default("My Default Workspace")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads     AgentThread[]
}

model AgentThread {
  id          String   @id @default(cuid())
  workspaceId String
  title       String?
  status      String   @default("ACTIVE")
  agentType   String   // ORCHESTRATOR, ADVISORY_BOARD, FINANCIER
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id          String   @id @default(cuid())
  threadId    String
  role        String   // USER, AGENT, SYSTEM
  content     String   @db.Text
  modelUsed   String?  // claude, gemini, qwen, kimi, llama
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  thread      AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 4. Memory Graph & Librarian (Self-Learning)
// ----------------------------------------------------
model MemoryNode {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String   // 'lawyer', 'financier', 'all'
  category    String   // 'rule', 'preference', 'fact', 'correction'
  content     String   @db.Text
  confidence  Float    @default(1.0) // Decay mechanism (1.0 = solid, <0.5 = stale)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
